# Example local overrides for launching AgentGL jobs.
#
# Copy or edit this file for your machine. The release training scripts also
# source config/agentgl.env, so only values that differ from the defaults need
# to be set here.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export AGENTGL_PROJECT_ROOT="${AGENTGL_PROJECT_ROOT:-$(cd "${SCRIPT_DIR}/.." && pwd)}"

export AGENTGL_OUTPUT_ROOT="${AGENTGL_OUTPUT_ROOT:-/path/to/agentgl_outputs}"
export AGENTGL_LOG_DIR="${AGENTGL_LOG_DIR:-${AGENTGL_PROJECT_ROOT}/logs}"

export AGENTGL_NODE_DATA_ROOT="${AGENTGL_NODE_DATA_ROOT:-/path/to/node_data}"
export AGENTGL_EDGE_DATA_ROOT="${AGENTGL_EDGE_DATA_ROOT:-/path/to/edge_indices}"
export AGENTGL_GRAPH_ENCODER_PATH="${AGENTGL_GRAPH_ENCODER_PATH:-/path/to/all-roberta-large-v1}"

export AGENTGL_BASE_MODEL_NC_GRPO_STAGE1="${AGENTGL_BASE_MODEL_NC_GRPO_STAGE1:-Qwen/Qwen2.5-3B-Instruct}"
export AGENTGL_BASE_MODEL_NC_REINFORCEPP_STAGE1="${AGENTGL_BASE_MODEL_NC_REINFORCEPP_STAGE1:-Qwen/Qwen2.5-7B-Instruct}"
export AGENTGL_BASE_MODEL_LP_GRPO_STAGE1="${AGENTGL_BASE_MODEL_LP_GRPO_STAGE1:-Qwen/Qwen2.5-3B-Instruct}"
export AGENTGL_BASE_MODEL_LP_REINFORCEPP_STAGE1="${AGENTGL_BASE_MODEL_LP_REINFORCEPP_STAGE1:-Qwen/Qwen2.5-3B-Instruct}"

export AGENTGL_CONDA_ROOT="${AGENTGL_CONDA_ROOT:-/path/to/miniconda3}"
export AGENTGL_CONDA_ENV="${AGENTGL_CONDA_ENV:-agentgl}"

export AGENTGL_CUDA_VISIBLE_DEVICES="${AGENTGL_CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"
export AGENTGL_EMBEDDING_DEVICE="${AGENTGL_EMBEDDING_DEVICE:-cuda:7}"
export AGENTGL_EMBEDDING_PORT="${AGENTGL_EMBEDDING_PORT:-9100}"
export AGENTGL_REWARD_PORT="${AGENTGL_REWARD_PORT:-1278}"
export AGENTGL_RAY_PORT="${AGENTGL_RAY_PORT:-8266}"
export AGENTGL_RAY_DASHBOARD_PORT="${AGENTGL_RAY_DASHBOARD_PORT:-8267}"
export AGENTGL_RAY_ADDRESS="${AGENTGL_RAY_ADDRESS:-http://127.0.0.1:${AGENTGL_RAY_DASHBOARD_PORT}}"
export AGENTGL_RAY_GCS_ADDRESS="${AGENTGL_RAY_GCS_ADDRESS:-127.0.0.1:${AGENTGL_RAY_PORT}}"
export AGENTGL_RAY_NUM_GPUS="${AGENTGL_RAY_NUM_GPUS:-8}"

# Optional. Leave unset to disable W&B in the release scripts.
# export AGENTGL_WANDB_API_KEY=""
