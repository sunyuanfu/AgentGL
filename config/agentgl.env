# AgentGL default runtime configuration.
#
# Override any value from your shell, or point AGENTGL_ENV_FILE to another env
# file before launching a script. Keep local absolute paths in an ignored
# config/local*.env file instead of editing the release scripts.

AGENTGL_OUTPUT_ROOT="${AGENTGL_OUTPUT_ROOT:-${AGENTGL_PROJECT_ROOT}/outputs}"
AGENTGL_LOG_DIR="${AGENTGL_LOG_DIR:-${AGENTGL_PROJECT_ROOT}/logs}"

AGENTGL_NODE_DATA_ROOT="${AGENTGL_NODE_DATA_ROOT:-${AGENTGL_PROJECT_ROOT}/node_data}"
AGENTGL_EDGE_DATA_ROOT="${AGENTGL_EDGE_DATA_ROOT:-${AGENTGL_PROJECT_ROOT}/edge_indices}"
AGENTGL_GRAPH_ENCODER_PATH="${AGENTGL_GRAPH_ENCODER_PATH:-all-roberta-large-v1}"
AGENTGL_GRAPH_ENCODER_REMOTE_URL="${AGENTGL_GRAPH_ENCODER_REMOTE_URL:-http://127.0.0.1:9100/encode}"

AGENTGL_RAY_ADDRESS="${AGENTGL_RAY_ADDRESS:-http://127.0.0.1:8267}"
AGENTGL_REWARD_PORT="${AGENTGL_REWARD_PORT:-1278}"
AGENTGL_CUDA_VISIBLE_DEVICES="${AGENTGL_CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"

AGENTGL_DATASETS="${AGENTGL_DATASETS:-ogbn-arxiv,ogbn-products}"
AGENTGL_DATA_PROBS="${AGENTGL_DATA_PROBS:-0.5,0.5}"

AGENTGL_NC_TRAIN_DIR="${AGENTGL_NC_TRAIN_DIR:-${AGENTGL_PROJECT_ROOT}/data/training_set}"
AGENTGL_LP_TRAIN_ROOT="${AGENTGL_LP_TRAIN_ROOT:-${AGENTGL_PROJECT_ROOT}/data/link_prediction}"
AGENTGL_LP_STAGE_DIR="${AGENTGL_LP_STAGE_DIR:-${AGENTGL_PROJECT_ROOT}/data/link_prediction_stage}"

AGENTGL_BASE_MODEL_NC_GRPO_STAGE1="${AGENTGL_BASE_MODEL_NC_GRPO_STAGE1:-Qwen/Qwen2.5-3B-Instruct}"
AGENTGL_BASE_MODEL_NC_REINFORCEPP_STAGE1="${AGENTGL_BASE_MODEL_NC_REINFORCEPP_STAGE1:-Qwen/Qwen2.5-7B-Instruct}"
AGENTGL_BASE_MODEL_LP_GRPO_STAGE1="${AGENTGL_BASE_MODEL_LP_GRPO_STAGE1:-Qwen/Qwen2.5-3B-Instruct}"
AGENTGL_BASE_MODEL_LP_REINFORCEPP_STAGE1="${AGENTGL_BASE_MODEL_LP_REINFORCEPP_STAGE1:-Qwen/Qwen2.5-3B-Instruct}"

AGENTGL_N_SAMPLES="${AGENTGL_N_SAMPLES:-16}"
AGENTGL_EPISODES="${AGENTGL_EPISODES:-1}"
AGENTGL_TRAIN_BATCH_SIZE="${AGENTGL_TRAIN_BATCH_SIZE:-128}"
AGENTGL_ROLLOUT_BATCH_SIZE="${AGENTGL_ROLLOUT_BATCH_SIZE:-32}"
AGENTGL_LR="${AGENTGL_LR:-2e-6}"
AGENTGL_KL="${AGENTGL_KL:-0.0}"
AGENTGL_WARMUP="${AGENTGL_WARMUP:-0.0}"
AGENTGL_TEMPERATURE="${AGENTGL_TEMPERATURE:-1.0}"

AGENTGL_GRAPH_TOPK="${AGENTGL_GRAPH_TOPK:-5}"
AGENTGL_GRAPH_TOPK_SIMILAR="${AGENTGL_GRAPH_TOPK_SIMILAR:-5}"
AGENTGL_GRAPH_TOPK_ONE_HOP="${AGENTGL_GRAPH_TOPK_ONE_HOP:-5}"
AGENTGL_GRAPH_TOPK_TWO_HOP="${AGENTGL_GRAPH_TOPK_TWO_HOP:-5}"
AGENTGL_GRAPH_TOPK_PAGERANK="${AGENTGL_GRAPH_TOPK_PAGERANK:-5}"
